# ============================================================
#  COHERENCE-26 — Environment Variables (Example)
#  Copy this file to .env and fill in your actual values.
#  DO NOT COMMIT .env
# ============================================================

# Ethereum Wallet (Hoodi Testnet)
PRIVATE_KEY=your_private_key_here
WALLET_ADDRESS=0xYourWalletAddressHere

# Alchemy API Key (for RPC / node access)
ALCHEMY_API_KEY=your_alchemy_api_key

# Etherscan API Key (for contract verification on Hoodi Etherscan)
ETHERSCAN_API_KEY=your_etherscan_api_key

# Hoodi Testnet Config
HOODI_RPC_URL=https://ethereum-hoodi-rpc.publicnode.com
HOODI_CHAIN_ID=560048
HOODI_EXPLORER_URL=https://hoodi.etherscan.io

# Deployed contract addresses (fill after running deploy script)
ROLE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
MERKLE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
COMMITMENT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
SLASHING_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
MULTISIG_REALLOCATION_ADDRESS=0x0000000000000000000000000000000000000000
WHISTLEBLOWER_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
MOCK_VRF_COORDINATOR_ADDRESS=0x0000000000000000000000000000000000000000
AUDIT_SCHEDULER_ADDRESS=0x0000000000000000000000000000000000000000
ZK_BUDGET_VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000

# FastAPI Backend
BACKEND_URL=http://localhost:8000

# Next.js Frontend (copy to jhol-khol/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id
